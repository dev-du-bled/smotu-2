{
  "compilerOptions": {
    "allowJs": false,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["@cloudflare/workers-types", "vite/client", "react", "react-dom"]
  },
  "include": ["src", "worker", "shared", "vite.config.ts"]
}
