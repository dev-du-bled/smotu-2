{
  "name": "smotu",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "deploy": "npm run build && npm run d1:migrate:remote && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "d1:migrate:local": "wrangler d1 migrations apply smotu-db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply smotu-db --remote"
  },
  "dependencies": {
    "@better-auth/i18n": "^1.6.23",
    "better-auth": "^1.6.23",
    "canvas-confetti": "^1.9.4",
    "drizzle-orm": "^0.45.2",
    "posthog-js": "^1.398.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.4",
    "@cloudflare/workers-types": "^4.20260701.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "wrangler": "^4.106.0"
  }
}
